---
const navItems = [
  { title: 'Architecture', href: '/category/architecture' },
  { title: 'Automotive', href: '/category/automotive' },
  { title: 'Interios', href: '/category/interios' },
  { title: 'Nature', href: '/category/nature' },
  { title: 'Objects', href: '/category/objects' },
  { title: 'About', href: '/about' },
  { title: 'Contact', href: '/contact' },
];

interface Props {
  class: string;
  activeCategory?: string;
}

const { class: extraClass = '', activeCategory } = Astro.props;
const rawPathName = Astro.url.pathname;

const pathName = rawPathName === '/' ? '/' : rawPathName.replace(/\/$/, '');
---

<nav class=`nav ${extraClass}` data-nav>
  <ul class="nav__list list-reset">
    {
      navItems.map((item) => {
        const cleanHref =
          item.href === '/' ? '/' : item.href.replace(/\/$/, '');
        const isActive =
          pathName === cleanHref ||
          pathName.startsWith(cleanHref + '/') ||
          activeCategory?.toLowerCase() === item.title.toLowerCase();

        return (
          <li class="nav__item">
            <a
              href={item.href}
              class:list={['nav__link', { 'nav__link--active': isActive }]}
              data-nav-link
            >
              {item.title}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

---
import { Image, getImage } from 'astro:assets';
import { projectCollections } from '@data/images';
import type { PhotoGallery } from '@appTypes/projectsTypes';
import defaultImage from '@assets/img/projects/no-photo.jpg';

interface Props {
  project: PhotoGallery;
}

const { project } = Astro.props;

const validPhotos =
  project.photos && project.photos.length > 0
    ? await Promise.all(
        project.photos.map(async (photoPath, idx) => {
          const imageData =
            projectCollections[`/src/assets${photoPath.src}`]?.default;

          if (!imageData) return null;

          const optimizedLargeImg = await getImage({
            src: imageData,
            width: 2000,
            format: 'webp',
          });

          const defaultAlt = `${project.title} — фото ${idx + 1}`;

          return {
            id: `${photoPath.src}-${idx}`,
            imageData,
            largeSrc: optimizedLargeImg.src,
            alt: photoPath.alt || defaultAlt,
            size: photoPath.size,
            loading: idx < 4 ? ('eager' as const) : ('lazy' as const),
            decoding: idx < 4 ? ('sync' as const) : ('async' as const),
          };
        }),
      )
    : [];

const photosToRender = validPhotos.filter(
  (photo): photo is NonNullable<typeof photo> => !!photo,
);
---

{
  photosToRender.length > 0 ? (
    photosToRender.map((photo) => (
      <li
        class:list={[
          'project-gallery__item',
          {
            'project-gallery__item--wide': photo.size === 'wide',
            'project-gallery__item--full': photo.size === 'full',
          },
        ]}
      >
        <a
          href={photo.largeSrc}
          class="project-gallery__link"
          data-fancybox="gallery"
        >
          <Image
            src={photo.imageData || defaultImage}
            alt={photo.alt}
            width={500}
            height={750}
            loading={photo.loading}
            decoding={photo.decoding}
            class="project-gallery__pic"
          />
        </a>
      </li>
    ))
  ) : (
    <p class="project-gallery__info">В этом проекте пока нет фотографий.</p>
  )
}

---
import { isRenderTemplateResult } from 'astro/runtime/server/render/astro/render-template.js';

const navItems = [
  { title: 'Architecture', href: '/category/architecture' },
  { title: 'Automotive', href: '/category/automotive' },
  { title: 'Interios', href: '/category/interios' },
  { title: 'Nature', href: '/category/nature' },
  { title: 'Objects', href: '/category/objects' },
  { title: 'About', href: '/about' },
  { title: 'Contact', href: '/contact' },
];

const { class: extraClass = '' } = Astro.props;
const pathName = Astro.url.pathname;
console.log('Name:', pathName);
---

<nav class=`nav ${extraClass}` data-nav>
  <ul class="nav__list list-reset">
    {
      navItems.map((item) => {
        const isActive = pathName === item.href;

        return (
          <li class="nav__item">
            <a
              href={item.href}
              class:list={['nav__link', { 'nav__link--active': isActive }]}
              data-nav-link
            >
              {item.title}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

---
import type { Author } from '@appTypes/authorTypes';

interface Props {
  author: Author;
}

const { author } = Astro.props;
---

<section class="author section-offset">
  <div class="container author__inner">
    <h1 class="visually-hidden">
      About the photo studio {author.name} — Biography and approach to work
    </h1>
    <span class="author__name">{author.name}</span>
    <span class="author__role">{author.role}</span>
    <p class="author__bio">{author.description}</p>
  </div>
</section>

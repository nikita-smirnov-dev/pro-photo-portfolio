---
// import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import Layout from '@layouts/BaseLayout.astro';
import { projects } from '@data/projects';
import { authorInfo } from '@data/author';
import ProjectGallery from '@components/projects/ProjectGallery.astro';

export function getStaticPaths() {
  const allId = [...new Set(projects.map((p) => p.id.toLowerCase()))];

  const result = allId.map((id) => ({
    params: { id: id },
  }));

  return result;
}

const { id } = Astro.params;

const filterId = projects.filter((p) => {
  return p.id.toLowerCase() === id;
});

const nameProject = id.charAt(0).toUpperCase() + id.slice(1);
---

<Layout title={`${nameProject} - ${authorInfo.name}`}>
  <section class="projects section-offset">
    <div class="container projects-work__inner">
      <h1 class="visually-hidden">
        {nameProject} — фотограф {authorInfo.name}
      </h1>
      {
        (
          <ul class="list-reset projects-work__list">
            {filterId.map((p) => (
              <li class="projects-work__item">
                <ProjectGallery project={p} />
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</Layout>
